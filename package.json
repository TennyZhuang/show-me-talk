{
  "name": "show-me-talk",
  "version": "0.1.3",
  "description": "Chrome extension that auto-collapses code in GitHub PRs so only the talk stays open.",
  "type": "module",
  "private": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:live": "npm run build && playwright test",
    "test": "npm run test:unit && npm run test:live",
    "browsers:install": "playwright install chromium",
    "package:extension": "npm run build && node scripts/create-release.mjs",
    "assets:store": "npm run build && node scripts/generate-store-assets.mjs"
  },
  "keywords": [
    "chrome-extension",
    "github",
    "pull-request",
    "manifest-v3",
    "playwright",
    "code-review"
  ],
  "author": "Tianyi Zhuang",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/chrome": "0.1.37",
    "@types/node": "25.3.5",
    "@crxjs/vite-plugin": "2.3.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.58.2",
    "eslint": "10.0.3",
    "globals": "16.5.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  }
}
